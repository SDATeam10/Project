@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml
left to right direction

LAYOUT_WITH_LEGEND()

Person(client, "Client", "Provider of source rust files, could be a user calling rust_analyzer directly or, more commonly, a user working with a IDE.")
System_Ext(ide, "Integrated Development Environment", "Software designed to write and modify source code effectively", "Software System")
System_Ext(file_system, "Host File System", "File System of the host machine. It allows to store and retrieve files.", "Software System")
System(system, "Rust Analizer", "Provides the users with common quality of life features such as: annotations, auto-imports, code completion, hover information and many others.", "Software System")

Rel(client, ide, "Provides source rust files")
Rel(ide, system, "Request information about the code, such as compile errors, autocomplete options, ...", "LSP / JSON")
Rel(system, ide, "Produces structured semantic model of source files", "LSP / JSON")
Rel(ide, client, "Displays source file with semantic meaning applied")
Rel(system, file_system, "Retrieves files", "OS API")

@enduml


