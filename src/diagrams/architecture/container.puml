@startuml
!pragma layout smetana
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml


LAYOUT_WITH_LEGEND()

Person(client, "Client", "Provider of source rust files, like a user working with an IDE.")
System_Ext(ide_ext, "Integrated Development Environment", "Software designed to write and modify source code effectively", "Software System")
System_Ext(file_system, "Host File System", "File System of the host machine. It allows to store and retrieve files.", "Software System")

System_Boundary(sb, "Rust Analyzer System", "SoftwareSystem"){
    Container(rustanalyzer, "Rust Analyzer", "Cargo/Crates", "LSP client for the Rust language.")
    Container(xtask, "xtask", "xtask", "Custom builder for rust-analyzer")
}

Rel(client, ide_ext, "Provides source rust files")
Rel(ide_ext, rustanalyzer, "Request information about the code, such as compile errors, autocomplete options, ...", "LSP / JSON")
Rel(rustanalyzer, ide_ext, "Produces structured semantic model of source files", "LSP / JSON")
Rel(ide_ext, client, "Displays source file with semantic meaning applied")
Rel(rustanalyzer, file_system, "Retrieves files")
Rel(xtask, rustanalyzer, "builds")

@enduml
